# ===========================
# Dragon Heart - .gitignore
# ===========================

# ============ BACKEND ============

# Node modules
node_modules/
backend/node_modules/

# Environment variables (IMPORTANTE!)
.env
backend/.env
*.env.local
*.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
backend/logs/

# Uploads (imagens dos produtos)
backend/uploads/
uploads/

# ============ SISTEMA ============

# MacOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ============ IDEs ============

# VSCode / Windsurf
.vscode/
.windsurf/
*.code-workspace

# JetBrains (WebStorm, IntelliJ, etc)
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.*.sw[a-p]

# ============ DEPENDÊNCIAS ============

# NPM
package-lock.json
npm-debug.log*
yarn.lock
.yarn/
.pnp.*

# ============ BUILD / DIST ============

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.cache/

# ============ TEMPORÁRIOS ============

# Arquivos temporários
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ============ TESTES ============

# Coverage
coverage/
*.lcov
.nyc_output/

# ============ BANCO DE DADOS ============

# Backups de banco
*.sql.backup
*.dump
*.bak.sql

# SQLite (se usar)
*.sqlite
*.sqlite3
*.db

# ============ DOCUMENTAÇÃO ============

# Arquivos de documentação temporários
*.md.backup
*.md~

# ============ OUTROS ============

# Certificados e chaves
*.pem
*.key
*.cert
*.crt

# Arquivos compactados
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ============ ESPECÍFICO DO PROJETO ============

# Arquivos de teste/desenvolvimento
test-uploads/
temp/
tmp/

# Arquivos de configuração local
config.local.js
settings.local.json
